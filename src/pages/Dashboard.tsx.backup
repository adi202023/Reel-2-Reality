import React, { useEffect, useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { Trophy, Users, Zap, Star, LogOut, User, Play, Film, Camera, Target } from 'lucide-react';
import { Button } from '../components/ui/button';
import ChallengeCard from '../components/ChallengeCard';
import { useTheme } from '../context/ThemeContext';

interface DashboardStats {
  totalChallenges: number;
  completedChallenges: number;
  points: number;
  rank: number;
}

const Dashboard: React.FC = () => {
  const navigate = useNavigate();
  const { theme, toggleTheme, isDark } = useTheme();
  const [user, setUser] = useState<any>(null);
  const [stats, setStats] = useState<DashboardStats>({
    totalChallenges: 0,
    completedChallenges: 0,
    points: 0,
    rank: 0
  });

  useEffect(() => {
    // Load user data from localStorage
    const userData = localStorage.getItem('user');
    const authToken = localStorage.getItem('authToken');

    if (userData && authToken) {
      const user = JSON.parse(userData);
      setUser(user);

      // Set user stats
      setStats({
        totalChallenges: 12,
        completedChallenges: user.completedChallenges || 8,
        points: user.points || 2450,
        rank: user.rank || 15
      });
    }
  }, []);

  const handleLogout = () => {
    localStorage.removeItem('user');
    localStorage.removeItem('authToken');
    navigate('/');
  };

  const challenges = [
    {
      id: 1,
      title: "Video Challenge",
      description: "Create a 30-second creative video showcasing your talent.",
      difficulty: "Medium",
      points: 250,
      timeLimit: 3600,
      participants: 1250,
      icon: Camera,
      gradient: "from-purple-500 to-pink-500"
    },
    {
      id: 2,
      title: "Team Challenge",
      description: "Collaborate with 3 other creators on a group project.",
      difficulty: "Hard",
      points: 500,
      timeLimit: 7200,
      participants: 890,
      icon: Users,
      gradient: "from-blue-500 to-cyan-500"
    },
    {
      id: 3,
      title: "Speed Challenge",
      description: "Complete this challenge in under 10 minutes for bonus points.",
      difficulty: "Easy",
      points: 150,
      timeLimit: 600,
      participants: 2100,
      icon: Zap,
      gradient: "from-yellow-500 to-orange-500"
    },
    {
      id: 4,
      title: "Featured Challenge",
      description: "This week's featured challenge with premium rewards.",
      difficulty: "Hard",
      points: 750,
      timeLimit: 10800,
      participants: 567,
      icon: Star,
      gradient: "from-green-500 to-emerald-500"
    }
  ];

  if (!user) {
    return (
      <div className={`min-h-screen flex items-center justify-center transition-colors duration-300 ${
        isDark 
          ? 'bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900' 
          : 'bg-gradient-to-br from-gray-50 via-white to-gray-100'
      }`}>
        <div className={`text-center p-8 rounded-2xl border ${
          isDark 
            ? 'bg-white/5 backdrop-blur-sm border-white/10 text-white' 
            : 'bg-white/70 backdrop-blur-sm border-gray-200/50 text-gray-900 shadow-lg'
        }`}>
          <h2 className="text-2xl font-bold mb-4">Loading Dashboard...</h2>
          <p className={isDark ? 'text-gray-400' : 'text-gray-600'}>
            Please wait while we load your data.
          </p>
        </div>
      </div>
    );
  }

  return (
    <div className={`min-h-screen transition-colors duration-300 ${
      isDark 
        ? 'bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900' 
        : 'bg-gradient-to-br from-gray-50 via-white to-gray-100'
    }`}>
      {/* Header */}
      <header className="backdrop-blur-sm bg-black/20 border-b border-white/10">
        <div className="max-w-6xl mx-auto px-6 py-6">
          <div className="flex items-center justify-between">
            <div className="flex items-center space-x-4">
              <div className="w-12 h-12 bg-gradient-to-br from-yellow-400 to-orange-500 rounded-xl flex items-center justify-center">
                <Film className="w-7 h-7 text-black" />
              </div>
              <div>
                <h1 className="text-2xl font-bold text-white">Welcome back, {user?.name || 'User'}!</h1>
                <p className="text-gray-400">Ready for your next challenge?</p>
              </div>
            </div>

          <div className="flex items-center space-x-0.5">
            <Button
              variant="ghost"
              onClick={toggleTheme}
              className={`px-2 ${isDark ? 'text-gray-300 hover:text-white hover:bg-white/10' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}`}
            >
              <Star className="w-4 h-4 mr-2" />
            </Button>
            <Button
              variant="ghost"
              onClick={() => navigate('/friends')}
              className={`px-2 ${isDark ? 'text-gray-300 hover:text-white hover:bg-white/10' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}`}
            >
              <Users className="w-4 h-4 mr-1" />
              Friends
            </Button>
            <Button
              variant="ghost"
              onClick={() => navigate('/notifications')}
              className={`px-2 ${
                isDark 
                  ? 'bg-slate-700 hover:bg-slate-600 text-white' 
                  : 'bg-white hover:bg-gray-50 text-gray-900 border border-gray-200'
              }`}
            >
              <Zap className="w-4 h-4 mr-2" />
              Notifications
            </Button>
            <Button
              variant="ghost"
              onClick={() => navigate('/brand-challenges')}
              className={`px-2 ${
                isDark 
                  ? 'bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 text-white' 
                  : 'bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 text-white'
              }`}
            >
              <Star className="w-4 h-4 mr-2" />
              Brand Challenges
            </Button>
            <Button
              variant="ghost"
              onClick={() => navigate('/rewards')}
              className={`px-2 ${
                isDark 
                  ? 'bg-gradient-to-r from-green-600 to-blue-600 hover:from-green-500 hover:to-blue-500 text-white' 
                  : 'bg-gradient-to-r from-green-600 to-blue-600 hover:from-green-500 hover:to-blue-500 text-white'
              }`}
            >
              <Trophy className="w-4 h-4 mr-2" />
              Rewards Store
            </Button>
            <Button
              variant="ghost"
              onClick={() => navigate('/profile')}
              className={`px-2 ${isDark ? 'text-gray-300 hover:text-white hover:bg-white/10' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}`}
            >
              <User className="w-4 h-4 mr-1" />
              Profile
            </Button>
            <Button
              variant="ghost"
              onClick={() => navigate('/challenges')}
              className={`px-2 ${isDark ? 'text-gray-300 hover:text-white hover:bg-white/10' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}`}
            >
              <Target className="w-4 h-4 mr-1" />
              Challenges
            </Button>
            <Button
              variant="ghost"
              onClick={() => navigate('/leaderboard')}
              className={`px-2 ${isDark ? 'text-gray-300 hover:text-white hover:bg-white/10' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}`}
            >
              <Trophy className="w-4 h-4 mr-1" />
              Leaderboard
            </Button>
            <Button
              variant="ghost"
              onClick={handleLogout}
              className={`px-2 ${isDark ? 'text-gray-300 hover:text-white hover:bg-white/10' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100'}`}
            >
              <LogOut className="w-4 h-4 mr-1" />
              Logout
            </Button>
          </div>
          </div>
        </div>
      </header>

      {/* Main Content with Gap */}
      <main className="max-w-6xl mx-auto px-6 py-8 mt-6">
        {/* Stats Cards */}
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
          <div 
            onClick={() => navigate('/challenges')}
            className={`p-8 rounded-2xl cursor-pointer transition-all duration-300 hover:scale-105 border ${
              isDark 
                ? 'bg-white/5 backdrop-blur-sm border-white/10 hover:bg-white/10'
                : 'bg-white/70 backdrop-blur-sm border-gray-200/50 hover:bg-white/90 shadow-lg'
            }`}
          >
            <div className="flex items-center justify-between mb-4">
              <div className={`w-12 h-12 rounded-xl ${
                isDark ? 'bg-gradient-to-r from-yellow-400 to-orange-500' : 'bg-gradient-to-r from-blue-500 to-purple-600'
              } flex items-center justify-center`}>
                <Target className="w-6 h-6 text-white" />
              </div>
              <span className={`text-3xl font-bold ${
                isDark ? 'text-yellow-400' : 'text-blue-600'
              }`}>
                {stats.totalChallenges}
              </span>
            </div>
            <h3 className={`font-semibold mb-2 ${isDark ? 'text-white' : 'text-gray-900'}`}>
              Total Challenges
            </h3>
            <p className={`text-sm ${isDark ? 'text-gray-400' : 'text-gray-600'}`}>
              Available to join
            </p>
          </div>

          <div 
            onClick={() => navigate('/profile')}
            className={`p-8 rounded-2xl cursor-pointer transition-all duration-300 hover:scale-105 border ${
              isDark 
                ? 'bg-white/5 backdrop-blur-sm border-white/10 hover:bg-white/10'
                : 'bg-white/70 backdrop-blur-sm border-gray-200/50 hover:bg-white/90 shadow-lg'
            }`}
          >
            <div className="flex items-center justify-between mb-4">
              <div className={`w-12 h-12 rounded-xl ${
                isDark ? 'bg-gradient-to-r from-purple-500 to-pink-500' : 'bg-gradient-to-r from-green-500 to-emerald-500'
              } flex items-center justify-center`}>
                <Trophy className="w-6 h-6 text-white" />
              </div>
              <span className={`text-3xl font-bold ${
                isDark ? 'text-purple-400' : 'text-green-600'
              }`}>
                {stats.completedChallenges}
              </span>
            </div>
            <h3 className={`font-semibold mb-2 ${isDark ? 'text-white' : 'text-gray-900'}`}>
              Completed
            </h3>
            <p className={`text-sm ${isDark ? 'text-gray-400' : 'text-gray-600'}`}>
              Challenges finished
            </p>
          </div>

          <div 
            onClick={() => navigate('/profile')}
            className={`p-8 rounded-2xl cursor-pointer transition-all duration-300 hover:scale-105 border ${
              isDark 
                ? 'bg-white/5 backdrop-blur-sm border-white/10 hover:bg-white/10'
                : 'bg-white/70 backdrop-blur-sm border-gray-200/50 hover:bg-white/90 shadow-lg'
            }`}
          >
            <div className="flex items-center justify-between mb-4">
              <div className={`w-12 h-12 rounded-xl ${
                isDark ? 'bg-gradient-to-r from-pink-500 to-red-500' : 'bg-gradient-to-r from-orange-500 to-red-500'
              } flex items-center justify-center`}>
                <Zap className="w-4 h-4 mr-2" />
              </div>
              <span className={`text-3xl font-bold ${
                isDark ? 'text-pink-400' : 'text-orange-600'
              }`}>
                {stats.points.toLocaleString()}
              </span>
            </div>
            <h3 className={`font-semibold mb-2 ${isDark ? 'text-white' : 'text-gray-900'}`}>
              Points
            </h3>
            <p className={`text-sm ${isDark ? 'text-gray-400' : 'text-gray-600'}`}>
              Total earned
            </p>
          </div>

          <div 
            onClick={() => navigate('/leaderboard')}
            className={`p-8 rounded-2xl cursor-pointer transition-all duration-300 hover:scale-105 border ${
              isDark 
                ? 'bg-white/5 backdrop-blur-sm border-white/10 hover:bg-white/10'
                : 'bg-white/70 backdrop-blur-sm border-gray-200/50 hover:bg-white/90 shadow-lg'
            }`}
          >
            <div className="flex items-center justify-between mb-4">
              <div className={`w-12 h-12 rounded-xl ${
                isDark ? 'bg-gradient-to-r from-cyan-500 to-blue-500' : 'bg-gradient-to-r from-purple-500 to-pink-500'
              } flex items-center justify-center`}>
                <Star className="w-6 h-6 text-white" />
              </div>
              <span className={`text-3xl font-bold ${
                isDark ? 'text-cyan-400' : 'text-purple-600'
              }`}>
                #{stats.rank}
              </span>
            </div>
            <h3 className={`font-semibold mb-2 ${isDark ? 'text-white' : 'text-gray-900'}`}>
              Rank
            </h3>
            <p className={`text-sm ${isDark ? 'text-gray-400' : 'text-gray-600'}`}>
              Global position
            </p>
          </div>
        </div>

        {/* Quick Actions */}
        <div className={`p-8 rounded-2xl mb-12 border ${
          isDark 
            ? 'bg-white/5 backdrop-blur-sm border-white/10'
            : 'bg-white/70 backdrop-blur-sm border-gray-200/50 shadow-lg'
        }`}>
          <h2 className={`text-2xl font-bold mb-8 ${isDark ? 'text-white' : 'text-gray-900'}`}>
            Quick Actions
          </h2>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            <Button
              onClick={() => navigate('/challenges')}
              className={`p-6 h-auto flex-col space-y-3 ${
                isDark 
                  ? 'bg-gradient-to-r from-yellow-500 to-orange-500 hover:from-yellow-400 hover:to-orange-400 text-black'
                  : 'bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 text-white'
              } transition-all duration-300 transform hover:scale-105`}
            >
              <Target className="w-8 h-8" />
              <div className="text-center">
                <div className="font-semibold text-lg">Browse Challenges</div>
                <div className="text-sm opacity-90">Discover new challenges to join</div>
              </div>
            </Button>

            <Button
              onClick={() => navigate('/leaderboard')}
              className={`p-6 h-auto flex-col space-y-3 ${
                isDark 
                  ? 'bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-400 hover:to-pink-400 text-white'
                  : 'bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-500 hover:to-emerald-500 text-white'
              } transition-all duration-300 transform hover:scale-105`}
            >
              <Trophy className="w-8 h-8" />
              <div className="text-center">
                <div className="font-semibold text-lg">View Leaderboard</div>
                <div className="text-sm opacity-90">See top creators and your rank</div>
              </div>
            </Button>

            <Button
              onClick={() => navigate('/profile')}
              className={`p-6 h-auto flex-col space-y-3 ${
                isDark 
                  ? 'bg-gradient-to-r from-cyan-500 to-blue-500 hover:from-cyan-400 hover:to-blue-400 text-white'
                  : 'bg-gradient-to-r from-orange-600 to-red-600 hover:from-orange-500 hover:to-red-500 text-white'
              } transition-all duration-300 transform hover:scale-105`}
            >
              <User className="w-8 h-8" />
              <div className="text-center">
                <div className="font-semibold text-lg">Manage Profile</div>
                <div className="text-sm opacity-90">Update your profile and settings</div>
              </div>
            </Button>
          </div>
        </div>

        {/* Active Challenges */}
        <div className={`p-8 rounded-2xl border ${
          isDark 
            ? 'bg-white/5 backdrop-blur-sm border-white/10'
            : 'bg-white/70 backdrop-blur-sm border-gray-200/50 shadow-lg'
        }`}>
          <div className="flex items-center justify-between mb-8">
            <h2 className={`text-2xl font-bold ${isDark ? 'text-white' : 'text-gray-900'}`}>
              Active Challenges
            </h2>
            <Button
              variant="outline"
              onClick={() => navigate('/challenges')}
              className={`${
                isDark 
                  ? 'border-white/20 text-white hover:bg-white/10 hover:border-white/30'
                  : 'border-gray-300 text-gray-700 hover:bg-gray-50 hover:border-gray-400'
              }`}
            >
              View All
            </Button>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {challenges.map((challenge) => (
              <div
                key={challenge.id}
                className={`group p-6 rounded-2xl transition-all duration-300 hover:scale-105 border ${
                  isDark 
                    ? 'bg-white/5 backdrop-blur-sm border-white/10 hover:bg-white/10'
                    : 'bg-white/70 backdrop-blur-sm border-gray-200/50 hover:bg-white/90 shadow-lg'
                }`}
              >
                <div className={`w-12 h-12 rounded-xl bg-gradient-to-r ${challenge.gradient} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300`}>
                  <challenge.icon className="w-6 h-6 text-white" />
                </div>
                <h3 className={`font-bold text-lg mb-2 ${isDark ? 'text-white' : 'text-gray-900'}`}>
                  {challenge.title}
                </h3>
                <p className={`text-sm mb-4 ${isDark ? 'text-gray-400' : 'text-gray-600'}`}>
                  {challenge.description}
                </p>
                <div className="flex items-center justify-between text-sm">
                  <span className={`font-semibold ${
                    isDark ? 'text-yellow-400' : 'text-blue-600'
                  }`}>
                    {challenge.points} pts
                  </span>
                  <span className={isDark ? 'text-gray-400' : 'text-gray-600'}>
                    {challenge.participants} joined
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </main>
    </div>
  );
};

export default Dashboard;
