{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "reel-to-reality",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npm run build && npm run serve",
    "build": "npx expo export --platform web",
    "serve": "lsof -ti:3001 | xargs kill -9 2>/dev/null; node server/index.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev": "npx expo start --web --port 8081",
    "restart": "bash scripts/restart.sh",
    "fix": "bash scripts/fix.sh",
    "frontend": "bash scripts/frontend.sh",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@react-native-async-storage/async-storage": "~1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.8",
    "@react-navigation/material-top-tabs": "^6.6.3",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/stack": "^6.3.17",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "expo": "^54.0.7",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-status-bar": "~3.0.8",
    "lucide-react": "^0.263.1",
    "nativewind": "^2.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-vector-icons": "^10.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.5.1",
    "react-router-dom": "^6.15.0",
    "tailwind-merge": "^1.14.0",
    "tailwindcss": "^3.3.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/webpack-config": "^19.0.1",
    "@types/node": "^20.5.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@types/react-router-dom": "^5.3.3",
    "autoprefixer": "^10.4.14",
    "expo-module-scripts": "^3.5.2",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.24",
    "typescript": "~5.9.2",
    "webpack": "^5.83.1"
  },
  "private": true
}
